NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/manufacture
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=7d
TRUST_PROXY=false
SESSION_SECRET=manufacture-session-secret
SESSION_NAME=mf.sid
SESSION_COOKIE_MAX_AGE=604800000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
SIGNUP_TEST_OTP=1234
ADMIN_INVITE_TOKEN=bootstrap-admin-token
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=ap-south-1
AWS_S3_ACCESS_KEY_ID=your-access-key
AWS_S3_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_UPLOADS_FOLDER=uploads
APP_NAME=Manufacture App
APP_URL=http://localhost:3000
EMAIL_FROM=Manufacture App <noreply@manufacture-app.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_POOL_ENABLED=true
SMTP_POOL_MAX_CONNECTIONS=3
SMTP_POOL_MAX_MESSAGES=100
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_GREETING_TIMEOUT_MS=10000
NOTIFICATIONS_EMAIL_ENABLED=true
NOTIFICATIONS_PUSH_ENABLED=true
NOTIFICATIONS_DISPATCHER_ENABLED=true
NOTIFICATIONS_DISPATCH_INTERVAL_MS=10000
NOTIFICATIONS_DISPATCH_BATCH_SIZE=30
NOTIFICATION_RETRY_BASE_MS=30000
NOTIFICATION_RETRY_MAX_MS=1800000
EXPO_PUSH_ACCESS_TOKEN=
