{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_API_URL": "http://3.108.52.140/api",
        "EXPO_PUBLIC_RAZORPAY_KEY_ID": "rzp_test_REPLACE_ME"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_API_URL": "http://3.108.52.140/api",
        "EXPO_PUBLIC_RAZORPAY_KEY_ID": "rzp_test_REPLACE_ME"
      }
    },
    "staging": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "dev",
        "EXPO_PUBLIC_API_URL": "http://3.108.52.140/api",
        "EXPO_PUBLIC_RAZORPAY_KEY_ID": "rzp_test_REPLACE_ME"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "autoIncrement": true
      },
      "env": {
        "APP_VARIANT": "prod",
        "EXPO_PUBLIC_API_URL": "https://api.arvann.in/api",
        "EXPO_PUBLIC_RAZORPAY_KEY_ID": "rzp_live_REPLACE_ME"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "REPLACE_WITH_APPLE_ID",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID",
        "appleTeamId": "REPLACE_WITH_TEAM_ID"
      }
    }
  }
}
